# Production reference (deferred) — set in Vercel dashboard when deploying

# DATABASE_URL=                         # injected by Neon Marketplace

# postgres.js pool (all required)
# DATABASE_POOL_MAX=1
# DATABASE_POOL_IDLE_TIMEOUT=0
# DATABASE_POOL_CONNECT_TIMEOUT=30
# DATABASE_POOL_MAX_LIFETIME=1800

# EMBEDDING_PROVIDER=vercel-gateway
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# AI_GATEWAY_API_KEY=                   # or VERCEL_OIDC_TOKEN on Vercel

# MCP_API_KEY=
# OLLAMA_BASE_URL not used in prod
