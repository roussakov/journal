# HCP Terraform + provider credentials (gitignored — copy from hcp.env.example)
# Source before terraform commands:  source hcp.env

# --- HCP Terraform (https://app.terraform.io/app/settings/tokens) ---
TF_CLOUD_ORGANIZATION=Journal
TF_WORKSPACE=journal-prod
TF_API_TOKEN=

# --- Vercel (https://vercel.com/account/tokens) ---
VERCEL_API_TOKEN=

# --- Neon (https://console.neon.tech/app/settings/api-keys) ---
NEON_API_KEY=
# Organization ID — Neon console → Organization settings
NEON_ORG_ID=
