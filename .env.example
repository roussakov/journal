# Local development (v1 active) — copy to .env at repo root

DATABASE_URL=postgresql://journal:journal@127.0.0.1:5432/journal

# postgres.js pool (all required — app crashes at startup if missing)
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=0
DATABASE_POOL_CONNECT_TIMEOUT=30
DATABASE_POOL_MAX_LIFETIME=1800

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
# Host Ollama (not Docker) — temporary: corporate firewall blocks in-container setup; started by pnpm dev
OLLAMA_BASE_URL=http://127.0.0.1:11434/api

# MCP_API_KEY=dev-key  # reserved — Bearer auth not wired in v1 local dev (see TODO.md)

# Postgres credentials (docker-compose; not read by app code)
# POSTGRES_USER=journal
# POSTGRES_PASSWORD=journal
# POSTGRES_DB=journal

# pgAdmin (docker-compose dev UI only)
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=admin
